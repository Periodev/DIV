{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "codegen",
            "type": "shell",
            "command": "python",
            "args": ["${workspaceFolder}/codegen.py"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "launch-godot",
            "type": "shell",
            "command": "D:/Godot/Godot_v4.6.1-stable_win64.exe/Godot_v4.6.1-stable_win64.exe",
            "args": ["--path", "${workspaceFolder}/godot"],
            "dependsOn": "codegen",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
